# IOTive Environment Variables Template
# Copy this file to '.env' and fill in your actual values.

# Google Sheets Web App URL (Google Apps Script) for contact form submissions
VITE_GOOGLE_SHEETS_URL=YOUR_GOOGLE_SHEETS_WEBAPP_URL

# Optional: Formspree ID for email notifications (e.g. VITE_FORMSPREE_ID=mvobgown)
VITE_FORMSPREE_ID=

# Fallback email displayed to users if submission fails
VITE_CONTACT_EMAIL=iotivetech@gmail.com
